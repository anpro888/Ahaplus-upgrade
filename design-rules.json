      "thead_font_weight": "600",
      "thead_color": "#616161",
      "tbody_font_size": "12px",
      "tbody_color": "#212121",
      "row_border": "1px solid #E0E0E0",
      "active_row_bg": "#F0F5E8",
      "deleted_row_bg": "#FFF5F5",
      "cell_padding": "9px 12px",
      "border_collapse": "collapse"
    },
    "toggle": {
      "width": "40px",
      "height": "22px",
      "thumb_size": "16px",
      "off_color": "#BDBDBD",
      "on_color": "#6161FF",
      "transition": "0.2s"
    }
