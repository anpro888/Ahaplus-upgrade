      "inactive_color": "#9E9E9E",
      "hover_bg": "#EEF0FF",
      "hover_border_radius": "4px 4px 0 0",
      "font_size": "13px",
      "active_weight": "600",
      "inactive_weight": "500",
      "padding": "10px 20px"
    },
    "modal": {
      "overlay_bg": "rgba(0,0,0,0.45)",
      "overlay_blur": "blur(4px)",
      "border_radius": "16px",
      "box_shadow": "0 8px 24px rgba(0,0,0,0.15)",
